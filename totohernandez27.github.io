<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Gustavo Ángel Hernández Mendoza | Supervisor de Atención al Cliente</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:wght@300;400;600;700&family=Jost:wght@300;400;500;600&display=swap" rel="stylesheet">
    <style>
        :root {
            --color-primary: #1a1a1a;
            --color-secondary: #4a4a4a;
            --color-accent: #C9A961;
            --color-light: #f5f5f5;
            --color-white: #ffffff;
            --font-display: 'Cormorant Garamond', serif;
            --font-body: 'Jost', sans-serif;
        }

        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        html {
            scroll-behavior: smooth;
        }

        body {
            font-family: var(--font-body);
            color: var(--color-primary);
            line-height: 1.6;
            background: var(--color-white);
        }

        /* Navigation */
        nav {
            position: fixed;
            top: 0;
            width: 100%;
            background: rgba(255, 255, 255, 0.95);
            backdrop-filter: blur(10px);
            z-index: 1000;
            border-bottom: 1px solid rgba(0, 0, 0, 0.05);
        }

        nav .container {
            max-width: 1400px;
            margin: 0 auto;
            padding: 1.5rem 2rem;
            display: flex;
            justify-content: space-between;
            align-items: center;
        }

        nav .logo {
            font-family: var(--font-display);
            font-size: 1.5rem;
            font-weight: 600;
            color: var(--color-primary);
            text-decoration: none;
        }

        nav ul {
            display: flex;
            list-style: none;
            gap: 2.5rem;
        }

        nav a {
            color: var(--color-secondary);
            text-decoration: none;
            font-weight: 400;
            font-size: 0.95rem;
            letter-spacing: 0.3px;
            transition: color 0.3s ease;
        }

        nav a:hover {
            color: var(--color-accent);
        }

        /* Hero Section */
        .hero {
            min-height: 100vh;
            display: flex;
            align-items: center;
            padding: 8rem 2rem 4rem;
            background: linear-gradient(135deg, #f5f5f5 0%, #ffffff 100%);
        }

        .hero .container {
            max-width: 1400px;
            margin: 0 auto;
            display: grid;
            grid-template-columns: 1fr 1.2fr;
            gap: 6rem;
            align-items: center;
        }

        .hero-image {
            position: relative;
        }

        .hero-image img {
            width: 100%;
            max-width: 450px;
            height: auto;
            border-radius: 2px;
            filter: grayscale(20%);
            transition: filter 0.3s ease;
        }

        .hero-image img:hover {
            filter: grayscale(0%);
        }

        .hero-content h1 {
            font-family: var(--font-display);
            font-size: 4.5rem;
            font-weight: 300;
            line-height: 1.1;
            margin-bottom: 1.5rem;
            letter-spacing: -1px;
        }

        .hero-content .subtitle {
            font-size: 1.3rem;
            color: var(--color-secondary);
            margin-bottom: 2rem;
            font-weight: 300;
        }

        .hero-content .tagline {
            font-size: 1.1rem;
            color: var(--color-secondary);
            margin-bottom: 3rem;
            max-width: 600px;
            line-height: 1.8;
        }

        .cta-buttons {
            display: flex;
            gap: 1.5rem;
            flex-wrap: wrap;
        }

        .btn {
            padding: 1rem 2.5rem;
            text-decoration: none;
            border-radius: 2px;
            font-weight: 500;
            transition: all 0.3s ease;
            display: inline-block;
            font-size: 0.95rem;
            letter-spacing: 0.5px;
            border: none;
            cursor: pointer;
        }

        .btn-primary {
            background: var(--color-primary);
            color: var(--color-white);
        }

        .btn-primary:hover {
            background: var(--color-accent);
        }

        .btn-secondary {
            background: transparent;
            color: var(--color-primary);
            border: 1px solid var(--color-primary);
        }

        .btn-secondary:hover {
            background: var(--color-primary);
            color: var(--color-white);
        }

        /* Social Links */
        .social-links {
            display: flex;
            gap: 1.5rem;
            margin-top: 2rem;
        }

        .social-links a {
            color: var(--color-secondary);
            font-size: 1.5rem;
            transition: color 0.3s ease;
        }

        .social-links a:hover {
            color: var(--color-accent);
        }

        /* Section Styling */
        section {
            padding: 6rem 2rem;
        }

        .container {
            max-width: 1200px;
            margin: 0 auto;
        }

        .section-title {
            font-family: var(--font-display);
            font-size: 3rem;
            font-weight: 300;
            margin-bottom: 1rem;
            letter-spacing: -0.5px;
        }

        .section-subtitle {
            font-size: 1.1rem;
            color: var(--color-secondary);
            margin-bottom: 4rem;
            max-width: 600px;
        }

        /* About Section */
        .about {
            background: var(--color-light);
        }

        .about-content {
            font-size: 1.15rem;
            line-height: 1.9;
            color: var(--color-secondary);
            max-width: 900px;
        }

        /* Skills Section */
        .skills-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
            gap: 2rem;
            margin-top: 3rem;
        }

        .skill-card {
            padding: 2.5rem;
            background: var(--color-white);
            border: 1px solid rgba(0, 0, 0, 0.08);
            transition: transform 0.3s ease, box-shadow 0.3s ease;
        }

        .skill-card:hover {
            transform: translateY(-5px);
            box-shadow: 0 10px 30px rgba(0, 0, 0, 0.1);
        }

        .skill-card h3 {
            font-family: var(--font-display);
            font-size: 1.5rem;
            margin-bottom: 1rem;
            font-weight: 600;
        }

        .skill-card p {
            color: var(--color-secondary);
            line-height: 1.7;
        }

        /* Experience Section */
        .experience-timeline {
            position: relative;
            padding-left: 3rem;
            margin-top: 3rem;
        }

        .experience-timeline::before {
            content: '';
            position: absolute;
            left: 0;
            top: 0;
            height: 100%;
            width: 1px;
            background: var(--color-accent);
        }

        .experience-item {
            position: relative;
            padding-bottom: 3rem;
            margin-bottom: 3rem;
            border-bottom: 1px solid rgba(0, 0, 0, 0.05);
        }

        .experience-item:last-child {
            border-bottom: none;
        }

        .experience-item::before {
            content: '';
            position: absolute;
            left: -3.35rem;
            top: 0.3rem;
            width: 12px;
            height: 12px;
            background: var(--color-accent);
            border-radius: 50%;
            border: 3px solid var(--color-white);
        }

        .experience-item .period {
            font-size: 0.9rem;
            color: var(--color-accent);
            font-weight: 500;
            margin-bottom: 0.5rem;
            letter-spacing: 0.5px;
        }

        .experience-item h3 {
            font-family: var(--font-display);
            font-size: 1.8rem;
            margin-bottom: 0.5rem;
            font-weight: 600;
        }

        .experience-item .company {
            font-size: 1.1rem;
            color: var(--color-secondary);
            margin-bottom: 1rem;
        }

        .experience-item ul {
            list-style: none;
            padding: 0;
        }

        .experience-item li {
            padding-left: 1.5rem;
            margin-bottom: 0.8rem;
            position: relative;
            color: var(--color-secondary);
            line-height: 1.7;
        }

        .experience-item li::before {
            content: '—';
            position: absolute;
            left: 0;
            color: var(--color-accent);
        }

        /* Portfolio Section */
        .portfolio {
            background: var(--color-light);
        }

        .portfolio-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(350px, 1fr));
            gap: 2.5rem;
            margin-top: 3rem;
        }

        .portfolio-card {
            background: var(--color-white);
            overflow: hidden;
            transition: transform 0.3s ease;
            border: 1px solid rgba(0, 0, 0, 0.05);
        }

        .portfolio-card:hover {
            transform: translateY(-8px);
        }

        .portfolio-card .card-content {
            padding: 2rem;
        }

        .portfolio-card h3 {
            font-family: var(--font-display);
            font-size: 1.6rem;
            margin-bottom: 1rem;
            font-weight: 600;
        }

        .portfolio-card p {
            color: var(--color-secondary);
            line-height: 1.7;
            margin-bottom: 1.5rem;
        }

        .portfolio-card .tags {
            display: flex;
            gap: 0.5rem;
            flex-wrap: wrap;
        }

        .tag {
            padding: 0.4rem 1rem;
            background: var(--color-light);
            font-size: 0.85rem;
            color: var(--color-secondary);
        }

        /* Testimonials Section */
        .testimonials-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(350px, 1fr));
            gap: 2.5rem;
            margin-top: 3rem;
        }

        .testimonial-card {
            padding: 2.5rem;
            background: var(--color-white);
            border-left: 3px solid var(--color-accent);
        }

        .testimonial-text {
            font-size: 1.1rem;
            line-height: 1.8;
            color: var(--color-secondary);
            margin-bottom: 1.5rem;
            font-style: italic;
        }

        .testimonial-author {
            display: flex;
            align-items: center;
            gap: 1rem;
        }

        .testimonial-author h4 {
            font-family: var(--font-display);
            font-size: 1.2rem;
            margin-bottom: 0.2rem;
        }

        .testimonial-author p {
            font-size: 0.9rem;
            color: var(--color-secondary);
        }

        /* Contact Section */
        .contact {
            background: var(--color-primary);
            color: var(--color-white);
        }

        .contact .section-title,
        .contact .section-subtitle {
            color: var(--color-white);
        }

        .contact-grid {
            display: grid;
            grid-template-columns: 1fr 1.5fr;
            gap: 4rem;
            margin-top: 3rem;
        }

        .contact-info h3 {
            font-family: var(--font-display);
            font-size: 1.8rem;
            margin-bottom: 1.5rem;
        }

        .contact-item {
            display: flex;
            align-items: center;
            gap: 1rem;
            margin-bottom: 1.5rem;
            color: rgba(255, 255, 255, 0.8);
        }

        .contact-item svg {
            width: 24px;
            height: 24px;
            color: var(--color-accent);
        }

        .contact-form {
            display: flex;
            flex-direction: column;
            gap: 1.5rem;
        }

        .form-group {
            display: flex;
            flex-direction: column;
        }

        .form-group label {
            margin-bottom: 0.5rem;
            font-weight: 500;
            font-size: 0.95rem;
        }

        .form-group input,
        .form-group textarea {
            padding: 1rem;
            background: rgba(255, 255, 255, 0.05);
            border: 1px solid rgba(255, 255, 255, 0.1);
            color: var(--color-white);
            font-family: var(--font-body);
            font-size: 1rem;
            transition: border-color 0.3s ease;
        }

        .form-group input:focus,
        .form-group textarea:focus {
            outline: none;
            border-color: var(--color-accent);
        }

        .form-group textarea {
            min-height: 150px;
            resize: vertical;
        }

        /* WhatsApp Button */
        .whatsapp-float {
            position: fixed;
            bottom: 2rem;
            right: 2rem;
            width: 60px;
            height: 60px;
            background: #25D366;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            box-shadow: 0 4px 20px rgba(0, 0, 0, 0.2);
            z-index: 999;
            transition: transform 0.3s ease;
            cursor: pointer;
        }

        .whatsapp-float:hover {
            transform: scale(1.1);
        }

        .whatsapp-float svg {
            width: 32px;
            height: 32px;
            color: white;
        }

        /* Footer */
        footer {
            background: var(--color-primary);
            color: rgba(255, 255, 255, 0.6);
            padding: 3rem 2rem;
            text-align: center;
            border-top: 1px solid rgba(255, 255, 255, 0.1);
        }

        /* Responsive */
        @media (max-width: 768px) {
            nav ul {
                display: none;
            }

            .hero .container {
                grid-template-columns: 1fr;
                gap: 3rem;
                text-align: center;
            }

            .hero-image img {
                max-width: 300px;
                margin: 0 auto;
            }

            .hero-content h1 {
                font-size: 3rem;
            }

            .contact-grid {
                grid-template-columns: 1fr;
            }

            .cta-buttons {
                justify-content: center;
            }

            .section-title {
                font-size: 2.5rem;
            }
        }

        /* Animations */
        @keyframes fadeInUp {
            from {
                opacity: 0;
                transform: translateY(30px);
            }
            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        .fade-in {
            animation: fadeInUp 0.8s ease forwards;
        }
    </style>
</head>
<body>
    <!-- Navigation -->
    <nav>
        <div class="container">
            <a href="#home" class="logo">GAH</a>
            <ul>
                <li><a href="#about">Sobre Mí</a></li>
                <li><a href="#skills">Competencias</a></li>
                <li><a href="#experience">Experiencia</a></li>
                <li><a href="#portfolio">Portfolio</a></li>
                <li><a href="#testimonials">Testimonios</a></li>
                <li><a href="#contact">Contacto</a></li>
            </ul>
        </div>
    </nav>

    <!-- Hero Section -->
    <section id="home" class="hero">
        <div class="container">
            <div class="hero-image">
                <img src="data:image/jpeg;base64," alt="Gustavo Ángel Hernández Mendoza" id="profile-photo">
            </div>
            <div class="hero-content">
                <h1>Gustavo Ángel<br>Hernández Mendoza</h1>
                <p class="subtitle">Supervisor de Atención al Cliente | Estratega en Experiencia del Consumidor</p>
                <p class="tagline">Transformando operaciones de servicio al cliente en motores de crecimiento mediante liderazgo estratégico, análisis de datos y excelencia operativa.</p>
                <div class="cta-buttons">
                    <a href="#contact" class="btn btn-primary">Contactar</a>
                    <button onclick="downloadCV()" class="btn btn-secondary">Descargar CV (PDF)</button>
                </div>
                <div class="social-links">
                    <a href="https://linkedin.com/in/tu-perfil" target="_blank" title="LinkedIn">
                        <svg width="24" height="24" fill="currentColor" viewBox="0 0 24 24"><path d="M19 0h-14c-2.761 0-5 2.239-5 5v14c0 2.761 2.239 5 5 5h14c2.762 0 5-2.239 5-5v-14c0-2.761-2.238-5-5-5zm-11 19h-3v-11h3v11zm-1.5-12.268c-.966 0-1.75-.79-1.75-1.764s.784-1.764 1.75-1.764 1.75.79 1.75 1.764-.783 1.764-1.75 1.764zm13.5 12.268h-3v-5.604c0-3.368-4-3.113-4 0v5.604h-3v-11h3v1.765c1.396-2.586 7-2.777 7 2.476v6.759z"/></svg>
                    </a>
                    <a href="mailto:toto27hernandez@gmail.com" title="Email">
                        <svg width="24" height="24" fill="currentColor" viewBox="0 0 24 24"><path d="M0 3v18h24v-18h-24zm6.623 7.929l-4.623 5.712v-9.458l4.623 3.746zm-4.141-5.929h19.035l-9.517 7.713-9.518-7.713zm5.694 7.188l3.824 3.099 3.83-3.104 5.612 6.817h-18.779l5.513-6.812zm9.208-1.264l4.616-3.741v9.348l-4.616-5.607z"/></svg>
                    </a>
                    <a href="tel:+525570097242" title="Teléfono">
                        <svg width="24" height="24" fill="currentColor" viewBox="0 0 24 24"><path d="M20 22.621l-3.521-6.795c-.008.004-1.974.97-2.064 1.011-2.24 1.086-6.799-7.82-4.609-8.994l2.083-1.026-3.493-6.817-2.106 1.039c-7.202 3.755 4.233 25.982 11.6 22.615.121-.055 2.102-1.029 2.11-1.033z"/></svg>
                    </a>
                </div>
            </div>
        </div>
    </section>

    <!-- About Section -->
    <section id="about" class="about">
        <div class="container">
            <h2 class="section-title">Sobre Mí</h2>
            <p class="section-subtitle">Líder operativo enfocado en resultados</p>
            <div class="about-content">
                <p>Líder operativo con más de 10 años de experiencia en la optimización de departamentos de Atención al Cliente y Ventas, especializado en el sector salud y farmacéutico. Mi enfoque combina la gestión estratégica de equipos de alto rendimiento con la implementación de procesos basados en KPIs y el dominio de sistemas ERP como SAP Business One y ASPEL SAE.</p>
                <br>
                <p>Me apasiona maximizar la retención de clientes mediante el análisis de datos y la mejora continua. Creo firmemente en que la excelencia en el servicio al cliente es el motor fundamental del crecimiento empresarial sostenible.</p>
            </div>
        </div>
    </section>

    <!-- Skills Section -->
    <section id="skills">
        <div class="container">
            <h2 class="section-title">Competencias Clave</h2>
            <p class="section-subtitle">Habilidades que impulsan resultados</p>
            <div class="skills-grid">
                <div class="skill-card">
                    <h3>Liderazgo</h3>
                    <p>Gestión de equipos multidisciplinarios, capacitación de personal y desarrollo de planes de carrera que maximizan el potencial humano.</p>
                </div>
                <div class="skill-card">
                    <h3>Operaciones</h3>
                    <p>Control de inventarios, logística de última milla, desarrollo de manuales de operación y optimización de procesos.</p>
                </div>
                <div class="skill-card">
                    <h3>Tecnología</h3>
                    <p>Dominio de SAP Business One, ASPEL SAE, Microsoft Office Avanzado y sistemas de gestión empresarial.</p>
                </div>
                <div class="skill-card">
                    <h3>Digital</h3>
                    <p>Estrategia de contenidos, análisis de métricas, CRM, SEO y gestión de comunidades digitales.</p>
                </div>
            </div>
        </div>
    </section>

    <!-- Experience Section -->
    <section id="experience" class="experience">
        <div class="container">
            <h2 class="section-title">Experiencia Profesional</h2>
            <p class="section-subtitle">Trayectoria de liderazgo y resultados</p>
            <div class="experience-timeline">
                <div class="experience-item">
                    <div class="period">MAYO 2023 - PRESENTE</div>
                    <h3>Supervisor de Atención al Cliente</h3>
                    <div class="company">Distribuidora MEDIHC S.A. DE C.V.</div>
                    <ul>
                        <li>Liderazgo de un equipo de atención y ventas, logrando un incremento significativo en la eficiencia de respuesta.</li>
                        <li>Supervisión de procesos de facturación y cobranza mediante SAP Business One, asegurando cero errores en el cierre mensual.</li>
                        <li>Desarrollo de manuales de operación que redujeron el tiempo de capacitación de nuevos ingresos en un 20%.</li>
                    </ul>
                </div>

                <div class="experience-item">
                    <div class="period">AGOSTO 2016 - ABRIL 2023</div>
                    <h3>Coordinador de Atención al Cliente / Operaciones</h3>
                    <div class="company">Signufarma S.A. DE C.V.</div>
                    <ul>
                        <li>Gestioné un equipo multidisciplinario (atención, almacén, choferes), garantizando el cumplimiento de los estándares de entrega de medicamentos de alta especialidad.</li>
                        <li>Implementé un sistema de seguimiento logístico para pacientes foráneos que mejoró sustancialmente la puntualidad de entrega.</li>
                        <li>Coordiné programas de apego a tratamiento, aumentando la fidelidad del paciente con la distribuidora.</li>
                    </ul>
                </div>

                <div class="experience-item">
                    <div class="period">JUNIO 2023 - ACTUALIDAD</div>
                    <h3>Estratega de Contenido y SEO</h3>
                    <div class="company">Proyectos Independientes / Consultoría Digital</div>
                    <ul>
                        <li>Desarrollo de estrategias de posicionamiento y contenido para proyectos digitales, aplicando conocimientos de SEO y analítica para aumentar el alcance orgánico.</li>
                        <li>Gestión de comunidades digitales y atención al usuario en plataformas sociales, optimizando la interacción y el engagement.</li>
                    </ul>
                </div>

                <div class="experience-item">
                    <div class="period">JULIO - DICIEMBRE 2012</div>
                    <h3>Customer Service Specialist</h3>
                    <div class="company">Pez Urbano S.A. DE C.V.</div>
                    <ul>
                        <li>Resolución de incidencias de alto nivel para usuarios de la plataforma, coordinando directamente con el área de logística para garantizar la satisfacción post-venta.</li>
                    </ul>
                </div>
            </div>
        </div>
    </section>

    <!-- Portfolio Section -->
    <section id="portfolio" class="portfolio">
        <div class="container">
            <h2 class="section-title">Portfolio de Proyectos</h2>
            <p class="section-subtitle">Casos de estudio y proyectos destacados</p>
            <div class="portfolio-grid">
                <div class="portfolio-card">
                    <div class="card-content">
                        <h3>Optimización de Procesos SAP B1</h3>
                        <p>Implementación y optimización del sistema SAP Business One para la gestión de facturación y cobranza, logrando cero errores en cierres mensuales.</p>
                        <div class="tags">
                            <span class="tag">SAP B1</span>
                            <span class="tag">Procesos</span>
                            <span class="tag">Eficiencia</span>
                        </div>
                    </div>
                </div>

                <div class="portfolio-card">
                    <div class="card-content">
                        <h3>Sistema de Seguimiento Logístico</h3>
                        <p>Desarrollo e implementación de sistema de tracking para entregas de medicamentos de alta especialidad, mejorando puntualidad y satisfacción del cliente.</p>
                        <div class="tags">
                            <span class="tag">Logística</span>
                            <span class="tag">Innovación</span>
                            <span class="tag">Salud</span>
                        </div>
                    </div>
                </div>

                <div class="portfolio-card">
                    <div class="card-content">
                        <h3>La Máquina del Cerebro</h3>
                        <p>Proyecto digital de contenido educativo y creativo, aplicando estrategias de SEO, marketing de contenidos y gestión de comunidades.</p>
                        <div class="tags">
                            <span class="tag">SEO</span>
                            <span class="tag">Contenido</span>
                            <span class="tag">Digital</span>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- Testimonials Section -->
    <section id="testimonials">
        <div class="container">
            <h2 class="section-title">Testimonios</h2>
            <p class="section-subtitle">Lo que dicen quienes han trabajado conmigo</p>
            <div class="testimonials-grid">
                <div class="testimonial-card">
                    <p class="testimonial-text">"Gustavo transformó completamente nuestro departamento de atención al cliente. Su capacidad para optimizar procesos y liderar equipos es excepcional."</p>
                    <div class="testimonial-author">
                        <div>
                            <h4>Director de Operaciones</h4>
                            <p>Distribuidora MEDIHC</p>
                        </div>
                    </div>
                </div>

                <div class="testimonial-card">
                    <p class="testimonial-text">"Su conocimiento de sistemas ERP y su visión estratégica fueron fundamentales para mejorar nuestros indicadores de servicio."</p>
                    <div class="testimonial-author">
                        <div>
                            <h4>Gerente General</h4>
                            <p>Signufarma</p>
                        </div>
                    </div>
                </div>

                <div class="testimonial-card">
                    <p class="testimonial-text">"Un profesional comprometido con la excelencia. Sus habilidades digitales complementan perfectamente su experiencia operativa."</p>
                    <div class="testimonial-author">
                        <div>
                            <h4>Cliente de Consultoría</h4>
                            <p>Proyecto Digital</p>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- Contact Section -->
    <section id="contact" class="contact">
        <div class="container">
            <h2 class="section-title">Contacto</h2>
            <p class="section-subtitle">¿Listo para trabajar juntos?</p>
            <div class="contact-grid">
                <div class="contact-info">
                    <h3>Información de Contacto</h3>
                    <div class="contact-item">
                        <svg fill="currentColor" viewBox="0 0 24 24"><path d="M12 0c-4.198 0-8 3.403-8 7.602 0 4.198 3.469 9.21 8 16.398 4.531-7.188 8-12.2 8-16.398 0-4.199-3.801-7.602-8-7.602zm0 11c-1.657 0-3-1.343-3-3s1.343-3 3-3 3 1.343 3 3-1.343 3-3 3z"/></svg>
                        <span>CDMX, México</span>
                    </div>
                    <div class="contact-item">
                        <svg fill="currentColor" viewBox="0 0 24 24"><path d="M20 22.621l-3.521-6.795c-.008.004-1.974.97-2.064 1.011-2.24 1.086-6.799-7.82-4.609-8.994l2.083-1.026-3.493-6.817-2.106 1.039c-7.202 3.755 4.233 25.982 11.6 22.615.121-.055 2.102-1.029 2.11-1.033z"/></svg>
                        <span>+52 55 70 09 72 42</span>
                    </div>
                    <div class="contact-item">
                        <svg fill="currentColor" viewBox="0 0 24 24"><path d="M0 3v18h24v-18h-24zm6.623 7.929l-4.623 5.712v-9.458l4.623 3.746zm-4.141-5.929h19.035l-9.517 7.713-9.518-7.713zm5.694 7.188l3.824 3.099 3.83-3.104 5.612 6.817h-18.779l5.513-6.812zm9.208-1.264l4.616-3.741v9.348l-4.616-5.607z"/></svg>
                        <span>toto27hernandez@gmail.com</span>
                    </div>
                </div>

                <form class="contact-form" onsubmit="handleSubmit(event)">
                    <div class="form-group">
                        <label for="name">Nombre</label>
                        <input type="text" id="name" name="name" required>
                    </div>
                    <div class="form-group">
                        <label for="email">Email</label>
                        <input type="email" id="email" name="email" required>
                    </div>
                    <div class="form-group">
                        <label for="message">Mensaje</label>
                        <textarea id="message" name="message" required></textarea>
                    </div>
                    <button type="submit" class="btn btn-primary">Enviar Mensaje</button>
                </form>
            </div>
        </div>
    </section>

    <!-- WhatsApp Float Button -->
    <a href="https://wa.me/525570097242" target="_blank" class="whatsapp-float" title="Contáctame por WhatsApp">
        <svg fill="currentColor" viewBox="0 0 24 24"><path d="M.057 24l1.687-6.163c-1.041-1.804-1.588-3.849-1.587-5.946.003-6.556 5.338-11.891 11.893-11.891 3.181.001 6.167 1.24 8.413 3.488 2.245 2.248 3.481 5.236 3.48 8.414-.003 6.557-5.338 11.892-11.893 11.892-1.99-.001-3.951-.5-5.688-1.448l-6.305 1.654zm6.597-3.807c1.676.995 3.276 1.591 5.392 1.592 5.448 0 9.886-4.434 9.889-9.885.002-5.462-4.415-9.89-9.881-9.892-5.452 0-9.887 4.434-9.889 9.884-.001 2.225.651 3.891 1.746 5.634l-.999 3.648 3.742-.981zm11.387-5.464c-.074-.124-.272-.198-.57-.347-.297-.149-1.758-.868-2.031-.967-.272-.099-.47-.149-.669.149-.198.297-.768.967-.941 1.165-.173.198-.347.223-.644.074-.297-.149-1.255-.462-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.297-.347.446-.521.151-.172.2-.296.3-.495.099-.198.05-.372-.025-.521-.075-.148-.669-1.611-.916-2.206-.242-.579-.487-.501-.669-.51l-.57-.01c-.198 0-.52.074-.792.372s-1.04 1.016-1.04 2.479 1.065 2.876 1.213 3.074c.149.198 2.095 3.2 5.076 4.487.709.306 1.263.489 1.694.626.712.226 1.36.194 1.872.118.571-.085 1.758-.719 2.006-1.413.248-.695.248-1.29.173-1.414z"/></svg>
    </a>

    <!-- Footer -->
    <footer>
        <p>&copy; 2025 Gustavo Ángel Hernández Mendoza. Todos los derechos reservados.</p>
    </footer>

    <script>
        // Load professional photo
        window.addEventListener('load', function() {
            const img = document.getElementById('profile-photo');
            // Aquí puedes reemplazar con la ruta real de tu foto
            // img.src = 'ruta-a-tu-foto.jpg';
        });

        // Download CV function
        function downloadCV() {
            alert('La funcionalidad de descarga de PDF se activará cuando tengas tu CV final en PDF. Por ahora puedes usar el botón de impresión del navegador (Ctrl+P) y guardar como PDF.');
            // En producción, podrías hacer:
            // window.location.href = 'path/to/your/cv.pdf';
        }

        // Handle form submission
        function handleSubmit(event) {
            event.preventDefault();
            const formData = new FormData(event.target);
            const data = {
                name: formData.get('name'),
                email: formData.get('email'),
                message: formData.get('message')
            };
            
            // Aquí podrías enviar los datos a un servicio como Formspree, EmailJS, etc.
            console.log('Form data:', data);
            alert('Gracias por tu mensaje. Te contactaré pronto.');
            event.target.reset();
        }

        // Smooth scroll animation
        document.querySelectorAll('a[href^="#"]').forEach(anchor => {
            anchor.addEventListener('click', function (e) {
                e.preventDefault();
                const target = document.querySelector(this.getAttribute('href'));
                if (target) {
                    target.scrollIntoView({
                        behavior: 'smooth',
                        block: 'start'
                    });
                }
            });
        });

        // Add fade-in animation on scroll
        const observerOptions = {
            threshold: 0.1,
            rootMargin: '0px 0px -50px 0px'
        };

        const observer = new IntersectionObserver(function(entries) {
            entries.forEach(entry => {
                if (entry.isIntersecting) {
                    entry.target.classList.add('fade-in');
                }
            });
        }, observerOptions);

        document.querySelectorAll('.skill-card, .experience-item, .portfolio-card, .testimonial-card').forEach(el => {
            observer.observe(el);
        });
    </script>
</body>
</html>
